#!/usr/bin/env bash
#
# libexec/pg-repl-diag/collect   (invoked as: pg-repl-diag collect)
# -----------------------------------------------------------------------------
# Static configuration collector (OS + PostgreSQL) relevant to replication
# lag diagnosis. STRICTLY READ-ONLY — it modifies nothing on the host or DB.
#
# Run this on EVERY node (Primary, local standby, remote standby) so the
# outputs can be compared side by side. It produces a single self-contained
# .txt report under REPORTS_DIR, suitable for handover to an analyst or vendor.
#
# CONFIGURATION: behaviour in repl.script.env, environment in repl.env (see repl.env.example).
#
# USAGE:
#   pg-repl-diag collect                          # collect local node only
#   pg-repl-diag collect <peer-ip-1> <peer-ip-2>  # also measure RTT to peers
#                                                 # (overrides PEERS from repl.env)
#
# Run as the 'postgres' OS user (or root) so configuration files and process
# level metrics are readable.
# -----------------------------------------------------------------------------

set -u

case "${1:-}" in
  -h|--help)
    cat <<'EOF'
pg-repl-diag collect — static OS + PostgreSQL configuration snapshot (run on EVERY node)

Usage:
  pg-repl-diag collect                          # local node only
  pg-repl-diag collect <peer-ip> [peer-ip...]   # also measure RTT to peers
                                                # (overrides PEERS from repl.env)

Strictly READ-ONLY. Writes one self-contained report to REPORTS_DIR. Passwords
are redacted. The OS sections still work even when psql cannot connect.

Key environment (repl.script.env / repl.env):
  REPORTS_DIR   where the report is written
  PEERS         default peer IPs for RTT when none are passed as arguments
  PGDATABASE/PGPORT/PGHOST/PGUSER   libpq connection
EOF
    exit 0 ;;
esac

# Load central configuration (repl.script.env + repl.env) and validation helpers.
# shellcheck source=../../lib/repl_common.sh
. "$(dirname "${BASH_SOURCE[0]}")/../../lib/repl_common.sh"

# This collector requires DB connectivity and an output directory.
require PGDATABASE "PostgreSQL database name"
require REPORTS_DIR "directory for collector reports"

PGDB="$PGDATABASE"

# Peer IPs for RTT: CLI arguments override the PEERS value from repl.env.
if [ "$#" -gt 0 ]; then
    PEERS=("$@")
else
    read -r -a PEERS <<< "${PEERS:-}"
fi

TS="$(date +%Y%m%d_%H%M%S)"
HOST="$(hostname 2>/dev/null || echo node)"
ensure_dir "$REPORTS_DIR"
OUT="${REPORTS_DIR}/repl_collect_${HOST}_${TS}.txt"

# Cap how long psql waits for a connection so a dead/hung server never blocks
# the whole collector. Honour an externally provided value if present.
export PGCONNECT_TIMEOUT="${PGCONNECT_TIMEOUT:-10}"

PSQL_S="psql -d ${PGDB} -X -At -q"            # scalar query helper
PSQL_T="psql -d ${PGDB} -X -q -P pager=off"   # tabular query helper

have(){ command -v "$1" >/dev/null 2>&1; }
# redact — strip secrets before anything reaches the report. Two patterns:
#   1. key/value form:  password = <secret>   (also PGPASSWORD, sslpassword; case-insensitive)
#   2. connection URI:  scheme://user:<secret>@host
redact(){
    sed -E '
      s/(password[[:space:]]*=[[:space:]]*)[^[:space:]"'"'"']+/\1***REDACTED***/Ig
      s#(://[^:@/[:space:]]+:)[^@/[:space:]]+@#\1***REDACTED***@#g
    '
}

# PHASE labels the terminal progress so it is obvious which half is running
# (OS vs PostgreSQL). collect_os / collect_db set it; prog() prepends it.
PHASE=""
exec 3>&1                                       # fd3 = terminal, used for progress
prog(){ step "${PHASE:+[$PHASE] }$*" >&3; }     # progress on the terminal (shared style)
sec(){ printf '\n========================================================================\n== %s\n========================================================================\n' "$*"; prog "$*"; }
sub(){ printf '\n--- %s ---\n' "$*"; }
run(){ # run "description" cmd...
    sub "$1"; shift
    if have "$1" 2>/dev/null || type "$1" >/dev/null 2>&1; then
        "$@" 2>&1 || echo "(failed / requires elevated privileges)"
    else
        echo "(command '$1' not available)"
    fi
}
psql_ok=0

# ============================================================================
# collect_os — OS / kernel / CPU / memory / storage / network / time config.
# Self-contained: needs NO database connectivity, so it stays useful even when
# psql cannot connect. Covers sections 1–10.
# ============================================================================
collect_os() {
PHASE="OS"

# ---------------------------------------------------------------------------
sec "1. OPERATING SYSTEM & KERNEL"
run "Kernel / uname"   uname -a
run "OS release"       cat /etc/os-release
run "Uptime / load"    uptime

# ---------------------------------------------------------------------------
sec "2. CPU  (WAL replay is single-threaded; per-core clock speed is decisive)"
if have lscpu; then run "lscpu" lscpu
else run "cpuinfo" sh -c "grep -E 'model name|MHz|processor' /proc/cpuinfo | sort -u"; fi

# ---------------------------------------------------------------------------
sec "3. MEMORY & VM TUNING"
run "Memory usage"     free -h
run "Huge pages"       sh -c "grep -i huge /proc/meminfo"
run "Transparent huge pages" sh -c "cat /sys/kernel/mm/transparent_hugepage/enabled 2>/dev/null"
run "VM sysctl"        sh -c "sysctl vm.swappiness vm.dirty_ratio vm.dirty_background_ratio vm.overcommit_memory 2>/dev/null"

# ---------------------------------------------------------------------------
sec "4. STORAGE & FILESYSTEM  (governs apply throughput on the standby)"
run "Filesystem usage" df -hT
if have lsblk; then run "Block devices" lsblk -o NAME,TYPE,SIZE,FSTYPE,ROTA,MOUNTPOINT,SCHED; fi
run "I/O scheduler"    sh -c "for q in /sys/block/*/queue/scheduler; do echo \"\$q: \$(cat \$q)\"; done 2>/dev/null"
run "Mount options"    sh -c "mount | grep -E 'ext4|xfs|zfs' "

# ---------------------------------------------------------------------------
sec "5. NETWORK — TCP SYSCTL  (core of single-stream throughput analysis)"
run "Active congestion control"    sh -c "sysctl net.ipv4.tcp_congestion_control"
run "Available congestion control" sh -c "sysctl net.ipv4.tcp_available_congestion_control"
run "Buffers & window scaling"     sh -c "sysctl net.core.rmem_max net.core.wmem_max \
    net.ipv4.tcp_rmem net.ipv4.tcp_wmem net.ipv4.tcp_window_scaling \
    net.ipv4.tcp_slow_start_after_idle net.ipv4.tcp_sack net.ipv4.tcp_timestamps \
    net.ipv4.tcp_mtu_probing net.core.netdev_max_backlog net.core.somaxconn 2>/dev/null"
run "Default qdisc"                sh -c "sysctl net.core.default_qdisc 2>/dev/null"

# ---------------------------------------------------------------------------
sec "6. NETWORK — NIC, MTU, ROUTING"
run "IP addresses" sh -c "ip -br addr 2>/dev/null || ip addr"
run "Links / MTU"  sh -c "ip -br link 2>/dev/null || ip link"
run "Routing table" sh -c "ip route 2>/dev/null"
if have ethtool; then
    for IF in $(ip -br link 2>/dev/null | awk '$2=="UP"{print $1}' | grep -v '^lo'); do
        sub "ethtool ${IF} (speed/duplex)"; ethtool "$IF" 2>&1 | grep -Ei 'speed|duplex|link detected' || echo "(requires root)"
        sub "ethtool -g ${IF} (ring buffers)"; ethtool -g "$IF" 2>&1 | head -20 || true
    done
else sub "ethtool"; echo "(ethtool not available)"; fi

# ---------------------------------------------------------------------------
sec "7. TIME / CLOCK SYNCHRONIZATION  (clock skew invalidates lag measurements)"
run "timedatectl" sh -c "timedatectl 2>/dev/null"
if have chronyc; then run "chrony tracking" chronyc tracking
elif have ntpq;  then run "ntpq peers" ntpq -p
else echo "(no chrony/ntp detected — ensure all three nodes share a synchronized clock)"; fi

# ---------------------------------------------------------------------------
sec "8. LIVE REPLICATION TCP SOCKET  (rtt, retransmits, cwnd from the real socket)"
# NB: run this in the bash context (NOT via `run ... sh -c`) so the redact()
# bash function is visible — sh -c spawns a new shell that does not inherit it.
PORT="${PGPORT:-5432}"
sub "Socket :${PORT}"
if have ss; then
    ss -tinp "( sport = :${PORT} or dport = :${PORT} )" 2>/dev/null | redact \
        || echo "(none found / root required for PID)"
else
    echo "(ss not available)"
fi
run "Global retransmit counters" sh -c "netstat -s 2>/dev/null | grep -i -E 'retrans|segments' | head"

# ---------------------------------------------------------------------------
sec "9. RTT TO PEERS"
if [ "${#PEERS[@]}" -eq 0 ]; then
    echo "(no peer IPs supplied. Set PEERS in repl.env, or run: $0 <peer-ip-1> <peer-ip-2>)"
else
    for P in "${PEERS[@]}"; do
        sub "ping $P"; ping -c 20 -i 0.2 -q "$P" 2>&1 | grep -E 'loss|rtt|round-trip' || echo "(unreachable)"
    done
fi

# ---------------------------------------------------------------------------
sec "10. RESOURCE LIMITS"
run "ulimit" sh -c "ulimit -a"
}

# ============================================================================
# collect_db — PostgreSQL identity, replication/WAL parameters, slots, stats.
# Sets the shared globals psql_ok / ROLE. Skips gracefully (with a clear note)
# when psql cannot connect; the OS report from collect_os remains useful on its
# own. Covers sections 11–19.
# ============================================================================
collect_db() {
PHASE="PostgreSQL"

# ===========================================================================
#  POSTGRESQL
# ===========================================================================
sec "11. POSTGRESQL — IDENTITY & ROLE"
if VER="$($PSQL_S -c 'SELECT version();' 2>/dev/null)"; then
    psql_ok=1
    echo "Version          : $VER"
    ROLE="$($PSQL_S -c "SELECT CASE WHEN pg_is_in_recovery() THEN 'STANDBY' ELSE 'PRIMARY' END;" 2>/dev/null)"
    echo "Role             : $ROLE"
    echo "Start time       : $($PSQL_S -c 'SELECT pg_postmaster_start_time();' 2>/dev/null)"
    echo "config_file      : $($PSQL_S -c 'SHOW config_file;' 2>/dev/null)"
    echo "data_directory   : $($PSQL_S -c 'SHOW data_directory;' 2>/dev/null)"
else
    echo "(!) Unable to connect via psql. Set PGHOST/PGPORT/PGUSER/.pgpass or run as the postgres user."
    echo "    The DB sections are skipped; the OS sections above remain useful."
fi

if [ "$psql_ok" = "1" ]; then
    sec "12. REPLICATION & WAL PARAMETERS  (listed explicitly, even when default)"
    $PSQL_T -c "
      SELECT name, setting, unit, source
      FROM pg_settings
      WHERE name IN (
        'wal_level','max_wal_senders','max_replication_slots','wal_compression',
        'wal_keep_size','synchronous_commit','synchronous_standby_names',
        'hot_standby','hot_standby_feedback','max_standby_streaming_delay',
        'recovery_min_apply_delay','primary_conninfo','primary_slot_name',
        'checkpoint_timeout','checkpoint_completion_target','max_wal_size','min_wal_size',
        'shared_buffers','effective_cache_size','wal_buffers','full_page_writes',
        'wal_writer_delay','listen_addresses','max_connections'
      ) ORDER BY name;" 2>&1 | redact

    sec "13. ALL NON-DEFAULT PARAMETERS  (intentionally overridden settings)"
    $PSQL_T -c "
      SELECT name, setting, unit, source
      FROM pg_settings
      WHERE source NOT IN ('default','override','client')
      ORDER BY source, name;" 2>&1 | redact

    if [ "${ROLE:-}" = "PRIMARY" ]; then
        sec "14. [PRIMARY] REPLICATION STATUS"
        $PSQL_T -x -c "SELECT * FROM pg_stat_replication;" 2>&1 | redact
        sub "Per-standby lag (bytes)"
        $PSQL_T -c "
          SELECT application_name, client_addr, state, sync_state,
                 pg_size_pretty(pg_wal_lsn_diff(sent_lsn, replay_lsn)) AS total_lag,
                 write_lag, flush_lag, replay_lag
          FROM pg_stat_replication;" 2>&1
        sub "WAL generation statistics (pg_stat_wal, PG14+)"
        $PSQL_T -x -c "SELECT * FROM pg_stat_wal;" 2>&1 || echo "(pg_stat_wal not available)"
    else
        sec "14. [STANDBY] RECOVERY STATUS"
        $PSQL_T -x -c "
          SELECT pg_is_in_recovery() AS in_recovery,
                 pg_last_wal_receive_lsn() AS receive_lsn,
                 pg_last_wal_replay_lsn()  AS replay_lsn,
                 pg_size_pretty(pg_wal_lsn_diff(pg_last_wal_receive_lsn(),
                                                pg_last_wal_replay_lsn())) AS unapplied_wal,
                 pg_last_xact_replay_timestamp() AS last_replay_ts,
                 round(extract(epoch FROM (now()-pg_last_xact_replay_timestamp()))::numeric,1) AS time_lag_seconds;" 2>&1
        sub "What the startup (redo) process is waiting on"
        $PSQL_T -c "SELECT backend_type, state, wait_event_type, wait_event
                    FROM pg_stat_activity WHERE backend_type='startup';" 2>&1
    fi

    sec "15. REPLICATION SLOTS"
    $PSQL_T -x -c "SELECT slot_name, slot_type, active, wal_status,
                          pg_size_pretty(safe_wal_size) AS safe_wal_size,
                          restart_lsn FROM pg_replication_slots;" 2>&1

    sec "16. CHECKPOINT / BACKGROUND WRITER"
    $PSQL_T -x -c "SELECT * FROM pg_stat_bgwriter;" 2>&1
    $PSQL_T -x -c "SELECT * FROM pg_stat_checkpointer;" 2>&1 || echo "(pg_stat_checkpointer is PG17+ only)"

    sec "17. ARCHIVER"
    $PSQL_T -x -c "SELECT * FROM pg_stat_archiver;" 2>&1

    sec "18. DATABASE SIZES & EXTENSIONS"
    $PSQL_T -c "SELECT datname, pg_size_pretty(pg_database_size(datname)) AS size
                FROM pg_database ORDER BY pg_database_size(datname) DESC LIMIT 15;" 2>&1
    $PSQL_T -c "SELECT extname, extversion FROM pg_extension ORDER BY 1;" 2>&1

    sec "19. postgresql.auto.conf  (ALTER SYSTEM overrides; passwords redacted)"
    AUTOCONF="$($PSQL_S -c 'SHOW data_directory;' 2>/dev/null)/postgresql.auto.conf"
    if [ -r "$AUTOCONF" ]; then cat "$AUTOCONF" | redact; else echo "(not readable: $AUTOCONF — run as the postgres user)"; fi
fi

}

# ============================================================================
# collect — orchestrator: report header, then the OS and PostgreSQL sections
# in order, producing ONE self-contained report (handover-friendly). The two
# halves live in collect_os / collect_db; this only sequences them.
# ============================================================================
collect() {
    printf 'REPLICATION DIAGNOSTICS — STATIC CONFIGURATION REPORT\nHost      : %s\nTimestamp : %s\nUser      : %s\n' \
        "$HOST" "$(date)" "$(whoami)"
    collect_os   # sections 1–10  (no DB required)
    collect_db   # sections 11–19 (skips itself if psql cannot connect)
    printf '\n======================== END OF REPORT ========================\n'
}

# ============================================================================
run_header "STATIC CONFIGURATION COLLECTOR"
step "Collecting diagnostics into: $OUT"
collect > "$OUT" 2>&1
ok "Report written: $OUT"
note "Submit the report '$OUT' for analysis."
note "Run this same script on ALL nodes so the outputs can be compared."
