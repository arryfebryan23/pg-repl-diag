#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
libexec/pg-repl-diag/dashboard — render the raw sampler CSVs into interactive HTML dashboards.
Invoked as: pg-repl-diag dashboard

No external dependencies (standard library only). Charts are drawn with inline
vanilla-JS canvas code, so the resulting HTML is 100% offline and safe to open
on air-gapped servers.

OUTPUT — three self-contained pages (derived from --out, default dashboard.html):
  dashboard.html           Overview: topology, roles, global verdict, links
  dashboard-primary.html   PRIMARY side: WAL rate + per-standby replication lag
  dashboard-standby.html   STANDBY side: apply/gap/disk/CPU/RTT + wait events

FEATURES:
  * Zoom & pan the time axis — scroll to zoom, drag to pan, double-click to reset.
    All charts on a page share one time window, so they stay aligned while you zoom.
  * Multi-day ready — axis labels add the date as the window widens, midnight
    boundaries are marked, and large datasets are decimated at draw time (full
    detail returns as you zoom in).
  * Multi-node / CASCADE ready — drop several nodes' CSVs into the metrics dir,
    prefixed with the node name, and each node is rendered separately:
        <node>_primary_metrics.csv   (a node that SENDS WAL)
        <node>_standby_metrics.csv   (a node that RECEIVES WAL)
    A node that appears under the SAME prefix in both roles (a cascading standby,
    or a standby promoted to primary) is flagged CASCADE on both dashboards.
    The bare default names map to two separate nodes — primary_metrics.csv -> node
    "primary", standby_metrics.csv -> node "standby" — so the ordinary one-primary,
    one-standby setup is NOT mistaken for a cascade.

CONFIGURATION: default input/output directories are read from the environment
(METRICS_DIR, BURST_DIR, DASHBOARD_DIR) and can be overridden with CLI flags.

USAGE:
  # directories are loaded from repl.env automatically by the dispatcher:
  pg-repl-diag dashboard
  # or pass them explicitly:
  pg-repl-diag dashboard --metrics-dir ./output/metrics --burst-dir ./output/bursts \\
                         --out ./output/dashboards/dashboard.html
"""
import argparse, csv, glob, json, os, html
from datetime import datetime


# --------------------------------------------------------------------------- #
# CSV parsing helpers
# --------------------------------------------------------------------------- #
def fnum(v):
    try:
        if v in ("", "-", None):
            return None
        return float(v)
    except (ValueError, TypeError):
        return None


def read_csv(path):
    rows = []
    if not path or not os.path.exists(path):
        return rows
    with open(path, newline="", encoding="utf-8", errors="replace") as f:
        for r in csv.DictReader(f):
            rows.append(r)
    return rows


def series(rows, ykey, xkey="ts_epoch"):
    out = []
    for r in rows:
        x, y = fnum(r.get(xkey)), fnum(r.get(ykey))
        if x is not None and y is not None:
            out.append({"x": x, "y": y})
    return out


def mb_series(rows, ykey):
    out = []
    for r in rows:
        x, y = fnum(r.get("ts_epoch")), fnum(r.get(ykey))
        if x is not None and y is not None:
            out.append({"x": x, "y": round(y / 1048576.0, 2)})
    return out


def summarize(vals):
    ys = [p["y"] for p in vals]
    if not ys:
        return {"last": None, "max": None, "avg": None}
    return {"last": ys[-1], "max": max(ys), "avg": round(sum(ys) / len(ys), 2)}


def extent(*lists_of_series):
    """Min/max x across any number of point lists."""
    xs = []
    for lst in lists_of_series:
        for p in lst:
            xs.append(p["x"])
    if not xs:
        return None
    return (min(xs), max(xs))


# --------------------------------------------------------------------------- #
# Node discovery (multi-node / cascade aware)
# --------------------------------------------------------------------------- #
def discover(metrics_dir, suffix, default_node):
    """Map node-name -> csv path for every *<suffix> file in metrics_dir.
    A bare 'primary_metrics.csv' -> node 'primary' (the default for that role),
    'standby_metrics.csv' -> node 'standby'; a prefixed 'edb2_primary_metrics.csv'
    -> node 'edb2'. Only a shared explicit prefix across both roles (e.g.
    edb2_primary + edb2_standby) marks a node as CASCADE."""
    found = {}
    for p in sorted(glob.glob(os.path.join(metrics_dir, "*" + suffix))):
        base = os.path.basename(p)
        node = base[: -len(suffix)].rstrip("_-") or default_node
        found[node] = p
    return found


def build_primary(rows):
    out = {"wal_rate": [], "standbys": {}}
    seen = set()
    for r in rows:
        ts = r.get("ts_epoch")
        if ts not in seen:
            wr = fnum(r.get("wal_rate_mbps"))
            if wr is not None:
                out["wal_rate"].append({"x": fnum(ts), "y": wr})
            seen.add(ts)
        name = r.get("standby") or "-"
        if name in ("(no-standby)", "-"):
            continue
        d = out["standbys"].setdefault(name, {"replay_lag": [], "total_lag_mb": [], "sync": "-"})
        d["sync"] = r.get("sync_state") or d["sync"]
        x = fnum(ts)
        rl = fnum(r.get("replay_lag_s"))
        tl = fnum(r.get("total_lag_bytes"))
        if x is not None and rl is not None:
            d["replay_lag"].append({"x": x, "y": rl})
        if x is not None and tl is not None:
            d["total_lag_mb"].append({"x": x, "y": round(tl / 1048576.0, 2)})
    return out


def build_standby(rows):
    d = {
        "time_lag":    series(rows, "time_lag_s"),
        "arrival":     series(rows, "arrival_mbps"),
        "apply":       series(rows, "apply_mbps"),
        "gap_mb":      mb_series(rows, "apply_gap_bytes"),
        "disk_util":   series(rows, "disk_util"),
        "cpu_startup": series(rows, "cpu_startup_pct"),
        "rtt":         series(rows, "sock_rtt_ms"),
        "retrans":     series(rows, "sock_retrans"),
        "waitevents":  {},
    }
    for r in rows:
        we = (r.get("wait_event") or "").strip()
        if we and we not in ("-", "-/-", "-/running"):
            d["waitevents"][we] = d["waitevents"].get(we, 0) + 1
    return d


def verdict_standby(sd, rowcount):
    """Heuristic apply/network verdict for one standby node."""
    text, cls, notes = "Insufficient data", "warn", []
    if not rowcount:
        return {"text": text, "cls": cls, "notes": notes}
    s_lag = summarize(sd["time_lag"])
    s_arr = summarize(sd["arrival"]); s_app = summarize(sd["apply"])
    s_util = summarize(sd["disk_util"]); s_cpu = summarize(sd["cpu_startup"])
    retr = sd["retrans"]
    retr_delta = (retr[-1]["y"] - retr[0]["y"]) if len(retr) >= 2 else None

    apply_slower = (s_arr["avg"] is not None and s_app["avg"] is not None
                    and s_app["avg"] < s_arr["avg"] * 0.9)
    lag_max = s_lag["max"] or 0
    if lag_max > 30 and apply_slower:
        if (s_util["max"] or 0) > 80:
            text, cls = "APPLY-BOUND -> standby disk I/O", "bad"
            notes.append(f"Disk %util peaked at {s_util['max']:.0f}% during high lag.")
        elif (s_cpu["max"] or 0) > 85:
            text, cls = "APPLY-BOUND -> single-thread CPU (redo)", "bad"
            notes.append(f"Startup process CPU peaked at {s_cpu['max']:.0f}% (one core saturated).")
        else:
            text, cls = "APPLY-BOUND -> standby not keeping up with WAL", "bad"
        notes.append(f"Average apply {s_app['avg'] or 0:.2f} MB/s < arrival {s_arr['avg'] or 0:.2f} MB/s.")
    elif lag_max > 30 and (s_arr["avg"] or 0) < 1.0:
        text, cls = "Likely NETWORK-BOUND (WAL arriving slowly)", "warn"
        notes.append(f"Low arrival ({s_arr['avg'] or 0:.2f} MB/s) despite high lag.")
        if retr_delta and retr_delta > 0:
            notes.append(f"Retransmits rose by {int(retr_delta)} over the period -> indicates packet loss.")
    elif lag_max <= 30:
        text, cls = "HEALTHY (lag under control during this period)", "good"
        notes.append(f"Peak time_lag {lag_max:.1f} s.")
    return {"text": text, "cls": cls, "notes": notes}


def cards_for_standby(sd):
    def c(title, sm, unit):
        return {"title": title, "last": sm["last"], "max": sm["max"], "avg": sm["avg"], "unit": unit}
    return [
        c("Replication lag", summarize(sd["time_lag"]), " s"),
        c("Apply rate", summarize(sd["apply"]), " MB/s"),
        c("Arrival rate", summarize(sd["arrival"]), " MB/s"),
        c("Disk %util", summarize(sd["disk_util"]), " %"),
        c("CPU redo (startup)", summarize(sd["cpu_startup"]), " %"),
        c("Socket RTT", summarize(sd["rtt"]), " ms"),
    ]


def load_bursts(burst_dir, kind):
    res = []
    if burst_dir and os.path.isdir(burst_dir):
        for bf in sorted(glob.glob(os.path.join(burst_dir, "burst_%s_*.txt" % kind))):
            try:
                with open(bf, encoding="utf-8", errors="replace") as f:
                    head = f.readline().strip()
            except OSError:
                head = ""
            res.append({"file": os.path.basename(bf), "head": head})
    return res


# --------------------------------------------------------------------------- #
# Arguments & discovery
# --------------------------------------------------------------------------- #
DEF_METRICS   = os.environ.get("METRICS_DIR", "./output/metrics")
DEF_BURST     = os.environ.get("BURST_DIR", "./output/bursts")
DEF_DASHBOARD = os.environ.get("DASHBOARD_DIR", "./output/dashboards")

ap = argparse.ArgumentParser(description="Render sampler CSVs into interactive HTML dashboards.")
ap.add_argument("--metrics-dir", default=DEF_METRICS, help="directory containing *_metrics.csv")
ap.add_argument("--burst-dir", default=DEF_BURST, help="directory containing burst_*.txt")
ap.add_argument("--primary", default=None, help="explicit path to a single primary_metrics.csv (node 'local')")
ap.add_argument("--standby", default=None, help="explicit path to a single standby_metrics.csv (node 'local')")
ap.add_argument("--out", default=os.path.join(DEF_DASHBOARD, "dashboard.html"),
                help="overview page path; the -primary/-standby pages are written alongside it")
args = ap.parse_args()

if args.primary or args.standby:
    primary_files = {"primary": args.primary} if args.primary else {}
    standby_files = {"standby": args.standby} if args.standby else {}
else:
    primary_files = discover(args.metrics_dir, "primary_metrics.csv", "primary")
    standby_files = discover(args.metrics_dir, "standby_metrics.csv", "standby")

# Build per-node payloads.
primary_nodes = []   # [{name, cascade, rows, wal_rate, standbys}]
standby_nodes = []   # [{name, cascade, rows, ...series, verdict, cards}]
all_xs = []          # for the global default time window

primary_names = set(primary_files)
standby_names = set(standby_files)
cascade_names = primary_names & standby_names

for name in sorted(primary_files):
    rows = read_csv(primary_files[name])
    pd = build_primary(rows)
    all_xs.append(pd["wal_rate"])
    for sb in pd["standbys"].values():
        all_xs.append(sb["replay_lag"]); all_xs.append(sb["total_lag_mb"])
    primary_nodes.append({
        "name": name, "cascade": name in cascade_names, "rows": len(rows),
        "wal_rate": pd["wal_rate"], "standbys": pd["standbys"],
        "wal_summary": summarize(pd["wal_rate"]),
    })

for name in sorted(standby_files):
    rows = read_csv(standby_files[name])
    sd = build_standby(rows)
    for k in ("time_lag", "arrival", "apply", "gap_mb", "disk_util", "cpu_startup", "rtt", "retrans"):
        all_xs.append(sd[k])
    node = {
        "name": name, "cascade": name in cascade_names, "rows": len(rows),
        "verdict": verdict_standby(sd, len(rows)),
        "cards": cards_for_standby(sd),
    }
    node.update(sd)
    standby_nodes.append(node)

xfull = extent(*all_xs) or (0, 1)

# Global verdict for the overview = worst standby verdict.
RANK = {"bad": 3, "warn": 2, "good": 1}
global_verdict = {"text": "No standby data collected", "cls": "warn", "notes": []}
best_rank = -1
for n in standby_nodes:
    r = RANK.get(n["verdict"]["cls"], 0)
    if r > best_rank:
        best_rank = r
        gv = dict(n["verdict"])
        gv["text"] = ("[%s] " % n["name"]) + gv["text"] if len(standby_nodes) > 1 else gv["text"]
        global_verdict = gv

bursts_primary = load_bursts(args.burst_dir, "primary")
bursts_standby = load_bursts(args.burst_dir, "standby")

meta = {
    "generated": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
    "span_from": datetime.fromtimestamp(xfull[0]).strftime("%Y-%m-%d %H:%M") if all_xs and xfull != (0, 1) else "-",
    "span_to":   datetime.fromtimestamp(xfull[1]).strftime("%Y-%m-%d %H:%M") if all_xs and xfull != (0, 1) else "-",
    "primary_node_count": len(primary_nodes),
    "standby_node_count": len(standby_nodes),
    "cascade_nodes": sorted(cascade_names),
}


