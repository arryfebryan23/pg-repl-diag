# Page: OVERVIEW (topology + global verdict + links)
# --------------------------------------------------------------------------- #
def render_overview():
    # topology rows: each known node with its role pills + facts
    nodes = {}
    for n in primary_nodes:
        e = nodes.setdefault(n["name"], {"roles": set(), "downstream": [], "wal": n["wal_summary"], "lag": None})
        e["roles"].add("primary")
        e["downstream"] = sorted(n["standbys"].keys())
    for n in standby_nodes:
        e = nodes.setdefault(n["name"], {"roles": set(), "downstream": [], "wal": None, "lag": None})
        e["roles"].add("standby")
        e["lag"] = summarize(n["time_lag"])["max"]

    rows = []
    for name in sorted(nodes):
        e = nodes[name]
        pills = ""
        if "primary" in e["roles"] and "standby" in e["roles"]:
            pills += '<span class="pill c">CASCADE</span>'
        if "primary" in e["roles"]:
            pills += '<span class="pill p">sends WAL</span>'
        if "standby" in e["roles"]:
            pills += '<span class="pill s">receives WAL</span>'
        downstream = ", ".join(e["downstream"]) if e["downstream"] else "—"
        wal = ("%.2f MB/s peak" % e["wal"]["max"]) if (e["wal"] and e["wal"]["max"] is not None) else "—"
        lag = ("%.1f s peak" % e["lag"]) if e["lag"] is not None else "—"
        rows.append("<tr><td><b>%s</b></td><td>%s</td><td>%s</td><td>%s</td><td>%s</td></tr>" % (
            html.escape(name), pills, html.escape(downstream), wal, lag))
    topo = ("<table class='topo'><tr><th>Node</th><th>Role</th><th>Downstream standbys</th>"
            "<th>WAL gen</th><th>Peak lag</th></tr>" + "".join(rows) + "</table>") if rows else \
           "<div class='empty'>No node CSVs found. Point --metrics-dir at your sampler output.</div>"

    casc_note = ""
    if meta["cascade_nodes"]:
        casc_note = ("<div class='verdict warn'>CASCADE topology detected: %s appears as both a WAL "
                     "sender and receiver. Its <b>standby</b> view (lag from its upstream) is on the Standby "
                     "dashboard; its <b>primary</b> view (lag to its downstream) is on the Primary dashboard.</div>"
                     % html.escape(", ".join(meta["cascade_nodes"])))

    body = (
        '<div class="verdict %s">VERDICT: %s<ul>%s</ul></div>' % (
            global_verdict["cls"], html.escape(global_verdict["text"]),
            "".join("<li>%s</li>" % html.escape(n) for n in global_verdict["notes"])) +
        casc_note +
        "<h2>Topology</h2>" + topo +
        '<div class="cards">'
        '<div class="card"><h4>Primary nodes</h4><div class="big">%d</div></div>'
        '<div class="card"><h4>Standby nodes</h4><div class="big">%d</div></div>'
        '<div class="card"><h4>Primary incidents</h4><div class="big">%d</div></div>'
        '<div class="card"><h4>Standby incidents</h4><div class="big">%d</div></div>'
        '</div>' % (meta["primary_node_count"], meta["standby_node_count"],
                    len(bursts_primary), len(bursts_standby)) +
        '<div class="burst"><h3>Primary incidents (burst captures)</h3><ul>%s</ul></div>' % burst_list_html(bursts_primary) +
        '<div class="burst"><h3>Standby incidents (burst captures)</h3><ul>%s</ul></div>' % burst_list_html(bursts_standby)
    )
    return shell("PostgreSQL Replication — Overview", "overview", header_sub(), body, "", {})


