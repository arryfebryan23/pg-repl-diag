def nav(active):
    items = [("dashboard.html", "Overview", "overview"),
             ("dashboard-primary.html", "Primary", "primary"),
             ("dashboard-standby.html", "Standby", "standby")]
    return "<nav>" + "".join(
        '<a class="%s" href="%s">%s</a>' % ("active" if key == active else "", href, label)
        for href, label, key in items) + "</nav>"


def shell(title, active, header_sub, body, init_js, data):
    page = SHELL
    return (page
            .replace("__TITLE__", html.escape(title))
            .replace("__CSS__", CSS)
            .replace("__NAV__", nav(active))
            .replace("__HEADER_SUB__", header_sub)
            .replace("__BODY__", body)
            .replace("__ENGINE__", ENGINE_JS)
            .replace("__DATA__", json.dumps(data))
            .replace("__INIT__", init_js))


SHELL = r"""<!doctype html>
<html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>__TITLE__</title>
<style>__CSS__</style></head>
<body>
<header>
  <h1>__TITLE__</h1>
  <div class="meta">__HEADER_SUB__</div>
  __NAV__
</header>
<div class="wrap">__BODY__</div>
<footer>Self-contained · rendered offline with no external libraries</footer>
<script>
__ENGINE__
const DATA = __DATA__;
__INIT__
</script>
</body></html>"""


def header_sub():
    cn = meta["cascade_nodes"]
    casc = (" · cascade node(s): " + ", ".join(cn)) if cn else ""
    return ("Generated %s · data window %s → %s · %d primary node(s), %d standby node(s)%s" % (
        html.escape(meta["generated"]), html.escape(meta["span_from"]), html.escape(meta["span_to"]),
        meta["primary_node_count"], meta["standby_node_count"], html.escape(casc)))


def burst_list_html(bursts):
    if not bursts:
        return "<li>No burst incidents recorded.</li>"
    return "".join('<li><b>%s</b> — %s</li>' % (html.escape(b["file"]), html.escape(b["head"])) for b in bursts)


