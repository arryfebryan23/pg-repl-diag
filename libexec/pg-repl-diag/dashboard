# Chart engine: zoom (wheel), pan (drag), reset (dblclick), shared time window
# across all charts on the page, draw-time min/max decimation, date-aware axis.
ENGINE_JS = r"""
const CHARTS=[];
let FULL={xMin:0,xMax:1}, VIEW={xMin:0,xMax:1};
const P2=n=>String(n).padStart(2,'0');
function fmtFull(ep){const d=new Date(ep*1000);
  return d.getFullYear()+'-'+P2(d.getMonth()+1)+'-'+P2(d.getDate())+' '+P2(d.getHours())+':'+P2(d.getMinutes())+':'+P2(d.getSeconds());}
function fmtShort(ep){const d=new Date(ep*1000);return P2(d.getMonth()+1)+'-'+P2(d.getDate())+' '+P2(d.getHours())+':'+P2(d.getMinutes());}
function tickLabel(ep,span){const d=new Date(ep*1000);
  if(span>2*86400) return P2(d.getMonth()+1)+'/'+P2(d.getDate());
  if(span>2*3600)  return P2(d.getMonth()+1)+'/'+P2(d.getDate())+' '+P2(d.getHours())+':'+P2(d.getMinutes());
  if(span>120)     return P2(d.getHours())+':'+P2(d.getMinutes());
  return P2(d.getHours())+':'+P2(d.getMinutes())+':'+P2(d.getSeconds());}

function setFull(mn,mx){if(!(mx>mn))mx=mn+1;FULL={xMin:mn,xMax:mx};VIEW={xMin:mn,xMax:mx};}
function clampView(mn,mx){const minSpan=2;
  if(mx-mn<minSpan){const c=(mn+mx)/2;mn=c-minSpan/2;mx=c+minSpan/2;}
  if(mn<FULL.xMin)mn=FULL.xMin; if(mx>FULL.xMax)mx=FULL.xMax;
  if(mx-mn<minSpan)mx=Math.min(FULL.xMax,mn+minSpan);
  return {xMin:mn,xMax:mx};}
function setView(mn,mx){VIEW=clampView(mn,mx);redrawAll();updateRange();}
function resetView(){VIEW={xMin:FULL.xMin,xMax:FULL.xMax};redrawAll();updateRange();}
function redrawAll(){CHARTS.forEach(c=>c.draw());}
function updateRange(){const el=document.getElementById('rangeReadout');
  if(el)el.textContent=fmtFull(VIEW.xMin)+'  to  '+fmtFull(VIEW.xMax);}

// Decimate to ~1 point per pixel using a min/max envelope (preserves spikes).
function decimate(data,xMin,xMax,w){
  if(!data.length)return [];
  const inView=[];
  for(let i=0;i<data.length;i++){const x=data[i].x;
    if(x>=xMin&&x<=xMax){if(!inView.length&&i>0)inView.push(data[i-1]);inView.push(data[i]);}
    else if(x>xMax){inView.push(data[i]);break;}}
  if(inView.length<=w*2)return inView;
  const span=(xMax-xMin)||1,out=[];let curPx=-1,lo=null,hi=null;
  const flush=()=>{if(lo&&hi){if(lo.x<=hi.x){out.push(lo);if(hi!==lo)out.push(hi);}else{out.push(hi);if(lo!==hi)out.push(lo);}}};
  for(const pt of inView){const px=Math.floor((pt.x-xMin)/span*w);
    if(px!==curPx){flush();curPx=px;lo=pt;hi=pt;}
    else{if(pt.y<lo.y)lo=pt;if(pt.y>hi.y)hi=pt;}}
  flush();return out;}

function makeChart(canvas,cfg){
  const padL=56,padR=14,padT=12,padB=26;
  function plot(){
    const dpr=window.devicePixelRatio||1,cssW=canvas.clientWidth,cssH=canvas.clientHeight;
    canvas.width=cssW*dpr;canvas.height=cssH*dpr;
    const ctx=canvas.getContext('2d');ctx.setTransform(dpr,0,0,dpr,0,0);
    const W=cssW,H=cssH,plotW=W-padL-padR,plotH=H-padT-padB;
    ctx.clearRect(0,0,W,H);
    const xMin=VIEW.xMin,xMax=VIEW.xMax,span=(xMax-xMin)||1;
    const dec=cfg.series.map(s=>decimate(s.data,xMin,xMax,plotW));
    let ys=[];dec.forEach(d=>d.forEach(p=>ys.push(p.y)));
    let yMax=cfg.yMax!=null?cfg.yMax:(ys.length?Math.max(...ys):1);
    if(cfg.yMax==null){yMax=yMax*1.1||1;}
    const yMin=0;
    if(!ys.length){ctx.fillStyle='#8b98a5';ctx.font='13px sans-serif';ctx.fillText('(no data in view)',padL,H/2);}
    const px=x=>padL+(x-xMin)/span*plotW;
    const py=y=>padT+plotH-(y-yMin)/((yMax-yMin)||1)*plotH;
    ctx.strokeStyle='#2a3441';ctx.fillStyle='#8b98a5';ctx.font='11px sans-serif';ctx.lineWidth=1;
    for(let i=0;i<=4;i++){const v=yMin+(yMax-yMin)*i/4,yy=py(v);
      ctx.beginPath();ctx.moveTo(padL,yy);ctx.lineTo(W-padR,yy);ctx.stroke();
      ctx.fillText(v>=100?v.toFixed(0):v.toFixed(1),6,yy+3);}
    // midnight boundary markers when the window spans hours/days
    if(span>3600){const d0=new Date(xMin*1000);d0.setHours(24,0,0,0);
      for(let t=d0.getTime()/1000;t<xMax;t+=86400){const X=px(t);
        ctx.strokeStyle='#3a4655';ctx.setLineDash([3,3]);
        ctx.beginPath();ctx.moveTo(X,padT);ctx.lineTo(X,padT+plotH);ctx.stroke();ctx.setLineDash([]);
        ctx.fillStyle='#6f7d8c';ctx.fillText(P2(new Date(t*1000).getMonth()+1)+'/'+P2(new Date(t*1000).getDate()),X+3,padT+11);}}
    ctx.fillStyle='#8b98a5';
    for(let i=0;i<=5;i++){const xv=xMin+span*i/5,X=px(xv);
      ctx.fillText(tickLabel(xv,span),Math.min(Math.max(X-20,2),W-46),H-8);}
    ctx.save();ctx.beginPath();ctx.rect(padL,padT,plotW,plotH);ctx.clip();
    cfg.series.forEach((s,si)=>{const d=dec[si];if(!d.length)return;
      ctx.strokeStyle=s.color;ctx.lineWidth=1.7;ctx.beginPath();
      d.forEach((p,i)=>{const X=px(p.x),Y=py(p.y);i?ctx.lineTo(X,Y):ctx.moveTo(X,Y);});ctx.stroke();});
    ctx.restore();
    canvas._g={padL,padR,padT,padB,W,H,plotW,plotH,xMin,xMax,span,dec};
  }
  function hover(mx){plot();const g=canvas._g;if(!g||mx<g.padL||mx>g.W-g.padR)return;
    const ctx=canvas.getContext('2d');
    const tx=g.xMin+(mx-g.padL)/g.plotW*g.span;
    ctx.strokeStyle='#5b6673';ctx.beginPath();ctx.moveTo(mx,g.padT);ctx.lineTo(mx,g.padT+g.plotH);ctx.stroke();
    let lines=[fmtFull(tx)];
    cfg.series.forEach((s,si)=>{const dd=g.dec[si];if(!dd||!dd.length)return;let best=null,bd=1e18;
      for(const p of dd){const k=Math.abs(p.x-tx);if(k<bd){bd=k;best=p;}}
      if(best)lines.push(s.name+': '+best.y);});
    const bw=180,bh=lines.length*15+8;let bx=mx+10;if(bx+bw>g.W)bx=mx-bw-10;if(bx<2)bx=2;
    ctx.fillStyle='rgba(8,12,18,.94)';ctx.fillRect(bx,g.padT,bw,bh);
    ctx.strokeStyle='#2a3441';ctx.strokeRect(bx,g.padT,bw,bh);
    ctx.fillStyle='#e6edf3';ctx.font='11px sans-serif';lines.forEach((l,i)=>ctx.fillText(l,bx+6,g.padT+15+i*15));}
  let dragging=false,lastX=0;
  canvas.addEventListener('wheel',e=>{e.preventDefault();
    const r=canvas.getBoundingClientRect(),mx=e.clientX-r.left;
    const frac=Math.min(Math.max((mx-padL)/(canvas.clientWidth-padL-padR),0),1);
    const xAt=VIEW.xMin+frac*(VIEW.xMax-VIEW.xMin),f=e.deltaY<0?0.8:1.25;
    setView(xAt-(xAt-VIEW.xMin)*f,xAt+(VIEW.xMax-xAt)*f);},{passive:false});
  canvas.addEventListener('mousedown',e=>{dragging=true;lastX=e.clientX;canvas.style.cursor='grabbing';});
  window.addEventListener('mouseup',()=>{dragging=false;canvas.style.cursor='crosshair';});
  canvas.addEventListener('mousemove',e=>{const r=canvas.getBoundingClientRect(),mx=e.clientX-r.left;
    if(dragging){const dx=e.clientX-lastX;lastX=e.clientX;const g=canvas._g;if(!g)return;
      const dt=-dx/g.plotW*g.span;setView(VIEW.xMin+dt,VIEW.xMax+dt);}else hover(mx);});
  canvas.addEventListener('mouseleave',()=>plot());
  canvas.addEventListener('dblclick',()=>resetView());
  const chart={draw:plot};CHARTS.push(chart);return chart;}

function chartBlock(title,hint,cfg){
  const d=document.createElement('div');d.className='chart';
  d.innerHTML='<h3>'+title+'</h3><div class="hint">'+hint+'</div><canvas></canvas>'+
    '<div class="legend">'+cfg.series.map(s=>'<span><i style="background:'+s.color+'"></i>'+s.name+'</span>').join('')+'</div>';
  document.getElementById('charts').appendChild(d);
  const cv=d.querySelector('canvas');requestAnimationFrame(()=>makeChart(cv,cfg).draw());}
function barBlock(title,hint,obj){
  const d=document.createElement('div');d.className='chart';
  const ent=Object.entries(obj).sort((a,b)=>b[1]-a[1]),max=ent.length?ent[0][1]:1;
  let h='<h3>'+title+'</h3><div class="hint">'+hint+'</div><div class="bars">';
  if(!ent.length)h+='<div class="empty">(no wait events recorded)</div>';
  ent.forEach(([k,v])=>{h+='<div class="bar"><span style="width:180px">'+k+'</span><div class="track"><div class="fill" style="width:'+(v/max*100)+'%"></div></div><span>'+v+'</span></div>';});
  h+='</div>';d.innerHTML=h;document.getElementById('charts').appendChild(d);}
function nodeHeader(text,badge){const d=document.createElement('div');d.className='nodehdr';
  d.innerHTML='<h2>'+text+'</h2>'+(badge?'<span class="badge">'+badge+'</span>':'');
  document.getElementById('charts').appendChild(d);}
function verdictBlock(v){if(!v)return;const d=document.createElement('div');d.className='verdict '+v.cls;
  d.innerHTML='VERDICT: '+v.text+'<ul>'+v.notes.map(n=>'<li>'+n+'</li>').join('')+'</ul>';
  document.getElementById('charts').appendChild(d);}
function cardsBlock(cards){const d=document.createElement('div');d.className='cards';
  d.innerHTML=cards.map(c=>{
    if(c.last==null)return '<div class="card"><h4>'+c.title+'</h4><div class="big">-</div></div>';
    return '<div class="card"><h4>'+c.title+'</h4><div class="big">'+c.last+'<span>'+c.unit+'</span></div>'+
           '<div class="sub">peak '+c.max+' · avg '+c.avg+'</div></div>';}).join('');
  document.getElementById('charts').appendChild(d);}

function initEngine(xfull){
  setFull(xfull[0],xfull[1]);updateRange();
