#!/usr/bin/env bash
#
# bin/pg-repl-diag
# -----------------------------------------------------------------------------
# Single entry point (dispatcher) for the PostgreSQL Replication Lag Diagnostics
# Toolkit. It routes a sub-command to the matching implementation under
# libexec/pg-repl-diag/. Put this one file on PATH (or symlink it) and every
# capability is reachable as `pg-repl-diag <command>`.
#
# All tunables live in repl.env (see repl.env.example); each sub-command loads it
# itself via lib/repl_common.sh, so per-invocation overrides keep working, e.g.:
#     INTERVAL=5 pg-repl-diag sample --role standby
# -----------------------------------------------------------------------------
set -u

PROG="$(basename "$0")"
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"
LIB="$ROOT/lib"
LIBEXEC="$ROOT/libexec/pg-repl-diag"

usage() {
    cat <<EOF
${PROG} — PostgreSQL replication-lag diagnostics

Usage: ${PROG} <command> [options]

Commands:
  collect [peer-ip...]     Static OS + DB configuration snapshot (run on EVERY node)
  net-test [standby-ip]    Single-stream vs parallel link test       (run on the PRIMARY)
  apply-check              Apply-gap / wait-event / disk probe        (run on the STANDBY)
  sample --role <r>        Periodic metrics sampler; r = primary | standby
  dashboard [args...]      Render collected CSVs into an HTML dashboard
  version                  Print the toolkit version
  help                     Show this help

Examples:
  ${PROG} collect 10.0.0.2 10.0.0.3
  ${PROG} net-test 10.0.0.2                 # start 'iperf3 -s' on the standby first
  ${PROG} apply-check
  INTERVAL=5 ${PROG} sample --role standby
  nohup ${PROG} sample --role primary >/dev/null 2>&1 &
  ${PROG} dashboard --out ./output/dashboards/dashboard.html

Configuration: copy repl.env.example to repl.env and edit it (or set REPL_ENV_FILE).
EOF
}

cmd="${1:-}"
[ "$#" -gt 0 ] && shift

case "$cmd" in
    collect)      exec "$LIBEXEC/collect"     "$@" ;;
    net-test)     exec "$LIBEXEC/net-test"    "$@" ;;
    apply-check)  exec "$LIBEXEC/apply-check" "$@" ;;

    sample)
        role=""
        args=()
        while [ "$#" -gt 0 ]; do
            case "$1" in
                --role)   role="${2:-}"; shift 2 ;;
                --role=*) role="${1#*=}"; shift ;;
                *)        args+=("$1"); shift ;;
            esac
        done
        case "$role" in
            primary) exec "$LIBEXEC/sample-primary" "${args[@]+"${args[@]}"}" ;;
            standby) exec "$LIBEXEC/sample-standby" "${args[@]+"${args[@]}"}" ;;
            "")  echo "${PROG} sample: --role is required (primary|standby)" >&2; exit 2 ;;
            *)   echo "${PROG} sample: unknown role '$role' (expected primary|standby)" >&2; exit 2 ;;
        esac
        ;;

    dashboard)
        # The dashboard is a Python tool that reads METRICS_DIR/BURST_DIR/DASHBOARD_DIR
        # from the environment. Source repl.env (no logging) so those are exported,
        # then hand off to python3.
        REPL_NO_LOG=1 . "$LIB/repl_common.sh"
        exec python3 "$LIBEXEC/dashboard" "$@"
        ;;

    version)
        # Run in a subshell so a missing repl.env doesn't abort the dispatcher.
        ( REPL_NO_LOG=1 . "$LIB/repl_common.sh" 2>/dev/null
          echo "${REPL_TOOLKIT_NAME:-pg-repl-diag} ${REPL_TOOLKIT_VERSION:-dev}" ) \
          || echo "pg-repl-diag (version unknown — repl.env not found)"
        ;;

    ""|help|-h|--help) usage ;;

    *)
        echo "${PROG}: unknown command '$cmd'" >&2
        echo "Run '${PROG} help' for the list of commands." >&2
        exit 2
        ;;
esac
