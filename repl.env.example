# ============================================================================
# repl.env — ENVIRONMENT configuration (PostgreSQL / OS / topology)
# ----------------------------------------------------------------------------
# Site-specific values that describe THIS deployment: the PostgreSQL connection,
# the standby/peer IPs, and the link bandwidth. Copy this file to 'repl.env' and
# adjust it per node. It is git-ignored so site values never get committed.
#
# Toolkit BEHAVIOUR (output paths, sampling cadence, thresholds, appearance)
# lives separately in 'repl.script.conf' (tracked in git).
#
# Loaded automatically by lib/repl_common.sh. Values already present in the
# environment take precedence (the ${VAR:-default} form), so per-invocation
# overrides still work, e.g.:
#     PGHOST=10.0.0.1 pg-repl-diag collect
#
# This file is sourced by bash — keep the VAR="${VAR:-default}" form.
# Do NOT store database passwords here; use ~/.pgpass (chmod 600) instead.
# ============================================================================

# ---- PostgreSQL connection (libpq) -----------------------------------------
PGHOST="${PGHOST:-/var/run/postgresql}"
PGPORT="${PGPORT:-5432}"
PGUSER="${PGUSER:-postgres}"
PGDATABASE="${PGDATABASE:-postgres}"

# ---- Topology (used by: pg-repl-diag net-test / pg-repl-diag collect) -------
TARGET="${TARGET:-}"                      # REQUIRED for the network test: standby IP running 'iperf3 -s' (no default)
LINK_MBPS="${LINK_MBPS:-1000}"            # this link's per-direction bandwidth (Mbps), for the BDP calculation
PEERS="${PEERS:-}"                        # optional: space-separated peer IPs for RTT, e.g. "10.0.0.2 10.0.0.3"
