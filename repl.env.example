# ============================================================================
# repl.env — central configuration for the Replication Lag Diagnostics Toolkit
# ----------------------------------------------------------------------------
# Copy this file to 'repl.env' and adjust the values. Every script loads it
# automatically via lib/repl_common.sh. Values already present in the
# environment take precedence (the ${VAR:-default} form), so per-invocation
# overrides still work, e.g.:
#     INTERVAL=5 bin/repl_sampler_standby.sh
#
# This file is sourced by bash — keep the VAR="${VAR:-default}" form.
# Do NOT store database passwords here; use ~/.pgpass (chmod 600) instead.
# ============================================================================

# ---- PostgreSQL connection (libpq) -----------------------------------------
PGHOST="${PGHOST:-/var/run/postgresql}"
PGPORT="${PGPORT:-5432}"
PGUSER="${PGUSER:-postgres}"
PGDATABASE="${PGDATABASE:-postgres}"

# ---- Output layout (all runtime artifacts live under OUTPUT_DIR) ------------
OUTPUT_DIR="${OUTPUT_DIR:-./output}"
METRICS_DIR="${METRICS_DIR:-${OUTPUT_DIR}/metrics}"        # sampler CSV files
REPORTS_DIR="${REPORTS_DIR:-${OUTPUT_DIR}/reports}"        # static collector reports
BURST_DIR="${BURST_DIR:-${OUTPUT_DIR}/bursts}"            # incident burst captures
DASHBOARD_DIR="${DASHBOARD_DIR:-${OUTPUT_DIR}/dashboards}" # generated HTML dashboards

# ---- Periodic sampling (repl_sampler_*.sh) ---------------------------------
INTERVAL="${INTERVAL:-10}"                # seconds between samples
THRESHOLD_LAG_S="${THRESHOLD_LAG_S:-30}"  # lag threshold (s) that triggers a burst capture
BURST_COOLDOWN="${BURST_COOLDOWN:-120}"   # minimum gap between bursts (s)
COUNT="${COUNT:-0}"                       # 0 = run indefinitely; >0 = stop after N samples

# ---- On-demand apply probe (repl_apply_diag.sh) ----------------------------
APPLY_INTERVAL="${APPLY_INTERVAL:-5}"     # seconds between samples
APPLY_COUNT="${APPLY_COUNT:-12}"          # number of samples (12 x 5s = 1 minute)

# ---- Network diagnosis (repl_network_diag.sh, run on the Primary) -----------
TARGET="${TARGET:-}"                      # REQUIRED: standby IP running 'iperf3 -s' (no default)
IPERF_PORT="${IPERF_PORT:-5201}"
DURATION="${DURATION:-20}"                # seconds per iperf3 test
PARALLEL="${PARALLEL:-8}"                 # streams for the capacity test
LINK_MBPS="${LINK_MBPS:-1000}"            # assumed per-direction link bandwidth (Mbps), for BDP
WAL_SAMPLE="${WAL_SAMPLE:-15}"            # seconds to sample WAL generation rate

# ---- Static collector (repl_collect.sh) ------------------------------------
PEERS="${PEERS:-}"                        # optional: space-separated peer IPs for RTT, e.g. "10.0.0.2 10.0.0.3"
